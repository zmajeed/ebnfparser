{
  "version": 10,
  "$comment": "ebnfparser cmake presets",
  "configurePresets": [
    {
      "name": "linux-release",
      "$comment": "Linux GCC release build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_COMPILER": "/usr/bin/g++-16",
        "CMAKE_C_COMPILER": "/usr/bin/gcc-16"
      }
    },
    {
      "name": "linux-debug",
      "$comment": "Linux GCC debug build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "/usr/bin/g++-16",
        "CMAKE_C_COMPILER": "/usr/bin/gcc-16"
      }
    },
    {
      "name": "windows-release",
      "$comment": "Windows VC++ release build",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-debug",
      "$comment": "Windows VC++ debug build",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-release",
      "configurePreset": "linux-release"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release"
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug"
    }
  ],
  "testPresets": [
    {
      "name": "linux-release",
      "configurePreset": "linux-release"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release"
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug"
    }
  ]
}
